# Supabase Postgres connection string (use the "Connection Pooling" URL from Supabase, port 6543, in production)
# Get this from: Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.xxx:***@aws-0-region.pooler.supabase.com:6543/postgres"

# Anthropic API key for modality classification and eligibility matching
# Get from: https://console.anthropic.com/
# 
# NOTE: You can skip this if using cheap/local alternatives below
ANTHROPIC_API_KEY="***"

# Optional: override the model used for classification (default: claude-haiku-4-5)
# CLASSIFICATION_MODEL="claude-haiku-4-5-20251001"

# Optional: override the model used for eligibility matching (default: claude-sonnet-4-6)
# MATCHING_MODEL="claude-sonnet-4-6"

# Public site URL (used in metadata, og tags). Update once you have a domain.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ============================================================================
# DEVELOPMENT MODE - No database required
# ============================================================================
# Set to "true" to use mock data instead of connecting to Supabase.
# This allows you to run and develop the UI without any database setup.
NEXT_PUBLIC_USE_MOCK_DB="false"

# ============================================================================
# CHEAP/TESTING OPTIONS - Avoid $10-15 in API costs
# ============================================================================

# Option A: Limit ingestion to first N trials for testing
# Then run: npm run ingest:limit (instead of ingest:full)
# INGEST_LIMIT="100"

# Option B: Use cheap keyword-based classification instead of Claude
# This is FREE but ~70% accurate. Good for testing.
# Run: npm run ingest:classify-cheap
# Or with local LLM (if you have Ollama): npm run ingest:classify-cheap-ollama
#
# To use keyword classification by default:
# USE_CHEAP_CLASSIFICATION="true"

# Option C: Use cheap rule-based matching instead of Claude Sonnet
# This is FREE but less nuanced - matches on age, sex, location only.
# Default LLM matching costs ~$0.10 per request.
# USE_CHEAP_MATCHING="true"

# Option D: Use dummy matching (for UI testing only)
# Returns fake results instantly. Zero cost. Zero accuracy.
# USE_DUMMY_MATCHING="true"

# ============================================================================
# COST COMPARISON (for ~50k trials)
# ============================================================================
#
# | Approach              | Classification | Matching    | Total         |
# |-----------------------|----------------|-------------|---------------|
# | Full Claude (default) | ~$10-15        | ~$0.10 each | Most accurate |
# | Keyword classification| FREE           | ~$0.10 each | Good for test |
# | Local LLM (Ollama)    | FREE           | ~$0.10 each | Better quality|
# | Rule-based matching   | FREE           | FREE        | 70% accurate  |
# | Dummy matching        | FREE           | FREE        | UI testing    |
#
# RECOMMENDED FOR TESTING:
# 1. Ingest 100 trials: npm run ingest:limit
# 2. Keyword classification: npm run ingest:classify-cheap
# 3. Rule-based matching: USE_CHEAP_MATCHING="true"
# Total cost: $0.00
