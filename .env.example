# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Supabase Postgres connection string (use the "Connection Pooling" URL, port 6543)
# Get this from: Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.xxx:***@aws-0-region.pooler.supabase.com:6543/postgres"


# ============================================================================
# AI PROVIDER CONFIGURATION (Choose ONE)
# ============================================================================

# Option A: QUADMAX - RECOMMENDED for unlimited Claude calls ($20/mo subscription)
# Best value for high-volume classification and matching
AI_PROVIDER="quadmax"
QUADMAX_API_KEY="sk-..."

# Option B: OPENAI - Pay per call, GPT-4o-mini is cheap (~$0.50 for 50k classifications)
# AI_PROVIDER="openai"
# OPENAI_API_KEY="sk-..."

# Option C: GEMINI - Cheapest option (~$0.10 for 50k classifications)
# AI_PROVIDER="gemini"
# GEMINI_API_KEY="..."

# Option D: ANTHROPIC - Original per-call pricing (most expensive, ~$15 for 50k)
# AI_PROVIDER="anthropic"
# ANTHROPIC_API_KEY="sk-ant-..."

# Option E: OLLAMA - Local models (FREE, requires local setup)
# AI_PROVIDER="ollama"
# No API key needed - runs on localhost:11434


# ============================================================================
# OPTIONAL: Override specific models
# ============================================================================

# Classification model (defaults based on provider)
# CLASSIFICATION_MODEL="claude-haiku-4-5-20251001"

# Matching models - tiered approach
# MATCHING_CHEAP_MODEL="claude-haiku-4-5-20251001"   # For simple cases
# MATCHING_STRONG_MODEL="claude-sonnet-4-6"          # For complex cases


# ============================================================================
# DEVELOPMENT MODE
# ============================================================================

# Use mock data instead of database - good for UI development
NEXT_PUBLIC_USE_MOCK_DB="false"

# Use cheap/free matching instead of LLM - good for testing
USE_CHEAP_MATCHING="false"

# Use dummy matching (fake results) - for UI testing only
USE_DUMMY_MATCHING="false"


# ============================================================================
# SITE CONFIGURATION
# ============================================================================

NEXT_PUBLIC_SITE_URL="http://localhost:3000"


# ============================================================================
# COST COMPARISON GUIDE
# ============================================================================
#
# Monthly costs at scale (~50k trials, 100 matches/month):
#
# | Provider    | Classification | Matching       | Total    | Best For          |
# |-------------|----------------|----------------|----------|-------------------|
# | QuadMax     | $0 (unlimited) | $0 (unlimited) | $20/mo   | High volume       |
# | Gemini      | ~$0.10         | ~$1.00         | ~$2/mo   | Lowest cost       |
# | OpenAI      | ~$0.50         | ~$3.00         | ~$4/mo   | Good balance      |
# | Anthropic   | ~$15           | ~$10           | ~$25/mo  | Best quality      |
# | Ollama      | $0             | $0             | $0*      | Self-hosted       |
#
# * Ollama requires GPU/CPU resources but no API costs
#
# RECOMMENDATION: QuadMax subscription ($20/mo) for production
# - Unlimited calls = no cost anxiety
# - Can use best model (Sonnet) for everything
# - Simpler than managing multiple providers
#
# For testing/development: Gemini or USE_CHEAP_MATCHING="true"
